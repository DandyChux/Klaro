{
	"build": {
		"beforeDevCommand": "bun run dev",
		"beforeBuildCommand": "bun run build",
		"devPath": "http://localhost:1420",
		"distDir": "../dist"
	},
	"package": {
		"productName": "rusty-scrubber",
		"version": "0.1.0"
	},
	"tauri": {
		"allowlist": {
			"all": false,
			"shell": {
				"all": false,
				"open": true
			},
			"dialog": {
				"all": true,
				"open": true,
				"save": true
			},
			"fs": {
				"all": true,
				"readFile": true,
				"writeFile": true,
				"scope": [
					"**"
				]
			}
		},
		"bundle": {
			"active": true,
			"targets": "all",
			"identifier": "com.dandychux.rusty-scrubber",
			"icon": [
				"icons/32x32.png",
				"icons/128x128.png",
				"icons/128x128@2x.png",
				"icons/icon.icns",
				"icons/icon.ico"
			]
		},
		"security": {
			"csp": null
		},
		"windows": [
			{
				"fullscreen": false,
				"resizable": true,
				"title": "Rusty Scrubber - Privacy Data Scrubber",
				"width": 1000,
				"height": 750,
				"minWidth": 800,
				"minHeight": 600
			}
		]
	}
}
